    <mxCell id="mlfq_title" value="&lt;b&gt;MLFQ - Multi-Level Feedback Queue&lt;/b&gt;&lt;br&gt;&lt;i&gt;Preemptive | Multiple Priority Queues with Demotion&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=#e1d5e7;fontSize=14;rounded=1;" vertex="1" parent="mlfq_page">
