      <mxGeometry x="305" y="415" width="190" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="mlfq4" value="Finished in Q1?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="mlfq_page">
      <mxGeometry x="305" y="525" width="190" height="70" as="geometry"/>
    </mxCell>

    <mxCell id="mlfq5" value="Terminate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="mlfq_page">
