    <mxCell id="mlfq8b" value="Terminate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="mlfq_page">
      <mxGeometry x="130" y="900" width="120" height="44" as="geometry"/>
    </mxCell>

    <!-- Demote to Q3 -->
    <mxCell id="mlfq_q3box" value="⬛ QUEUE 3 (Lowest Priority)&lt;br&gt;FCFS | No Time Limit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="mlfq_page">
